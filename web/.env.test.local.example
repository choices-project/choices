# E2E Test Configuration Example
# Copy this to .env.test.local and fill in your values
# NEVER commit .env.test.local to git!

# ===========================================================================
# TEST USER CREDENTIALS
# ===========================================================================
# These are the ONLY variables you need to set
# All Supabase credentials are loaded from .env.local automatically

# Admin test user (must exist in your database)
E2E_ADMIN_EMAIL=your-admin-email@example.com
E2E_ADMIN_PASSWORD=your-admin-password

# Regular test user (optional, for non-admin tests)
E2E_USER_EMAIL=your-user-email@example.com
E2E_USER_PASSWORD=your-user-password

# ===========================================================================
# SUPABASE CREDENTIALS (Auto-loaded from .env.local)
# ===========================================================================
# You don't need to set these - they're automatically loaded from .env.local
# Documented here for reference only:
#
# NEXT_PUBLIC_SUPABASE_URL - From .env.local
# NEXT_PUBLIC_SUPABASE_ANON_KEY - From .env.local  
# SUPABASE_SERVICE_ROLE_KEY - From .env.local
#
# ===========================================================================

# ===========================================================================
# SETUP INSTRUCTIONS
# ===========================================================================
# 
# 1. Copy this file:
#    cp .env.test.local.example .env.test.local
#
# 2. Edit .env.test.local and set:
#    - E2E_ADMIN_EMAIL (your test user email)
#    - E2E_ADMIN_PASSWORD (your test user password)
#
# 3. Verify configuration:
#    npm run test:e2e:check
#
# 4. Set admin flag:
#    npm run test:e2e:verify
#
# 5. Run tests:
#    npm run test:e2e
#
# ===========================================================================
