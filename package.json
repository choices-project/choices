{
  "name": "choices-repo",
  "private": true,
  "engines": {
    "node": ">=22.0.0 <25.0.0",
    "npm": ">=10.9.3"
  },
  "volta": {
    "node": "24.11.0",
    "npm": "11.6.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "~6.9.1",
    "@types/jest": "30.0.0",
    "@types/node": "22.10.2",
    "dotenv": "~17.2.1",
    "husky": "9.1.7",
    "typescript": "5.7.2"
  },
  "scripts": {
    "prepare": "husky install",
    "ci:install": "npm ci --ignore-scripts",
    "ci:verify": "npm audit --audit-level=moderate",
    "governance:check": "node scripts/check-governance.js",
    "verify:docs": "node scripts/verify-docs.mjs",
    "verify:doc-links": "node scripts/verify-doc-links.mjs",
    "verify:store-docs": "node scripts/verify-store-docs.mjs",
    "verify:architecture-boundaries": "node scripts/verify-architecture-boundaries.mjs",
    "verify:architecture-schema-counts": "node scripts/verify-architecture-schema-counts.mjs",
    "verify:env-example": "node scripts/verify-env-example.mjs",
    "verify:mcp-config": "node scripts/verify-mcp-config.mjs",
    "docs:feature-flags": "node scripts/generate-feature-flags-doc.mjs",
    "docs:security-snapshots": "node scripts/sync-security-snapshots.mjs",
    "docs:api-inventory": "node scripts/generate-api-inventory.mjs",
    "docs:public-schema-index": "node scripts/generate-public-schema-index.mjs",
    "docs:surface-counts": "node scripts/doc-surface-counts.mjs",
    "test": "npm run test --prefix web",
    "test:e2e": "npm run test:e2e --prefix web"
  },
  "dependencies": {
    "pg": "8.13.1",
    "shell-quote": "^1.8.3",
    "zod": "4.1.3"
  }
}
